package org.knovash.squeezealice.volumio;

public class RequestParameters {

    public static RequestToVolumioRest count() {
        return RequestToVolumioRest.create("", new String[]{"player", "count", "?"});
    }

    public static RequestToVolumioRest name(String index) {
        return RequestToVolumioRest.create("", new String[]{"player", "name", index, "?"});
    }

    public static RequestToVolumioRest id(String index) {
        return RequestToVolumioRest.create("", new String[]{"player", "id", index, "?"});
    }

    public static RequestToVolumioRest mode(String player) {
        return RequestToVolumioRest.create(player, new String[]{"mode", "?"});
    }

    public static RequestToVolumioRest pause(String player) {
        return RequestToVolumioRest.create(player, new String[]{"pause", "1"});
    }

    public static RequestToVolumioRest togglePlayPause(String player) {
        return RequestToVolumioRest.create(player, new String[]{"pause"});
    }

    public static RequestToVolumioRest play(String player) {
        return RequestToVolumioRest.create(player, new String[]{"pause", "0"});
    }

    public static RequestToVolumioRest play(String player, Integer id) {
        return RequestToVolumioRest.create(player, new String[]{"favorites", "playlist", "play", "item_id:" + id});
    }

    public static RequestToVolumioRest play(String player, String url) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "play", url});
    }

    public static RequestToVolumioRest favorites(String player, int value) {
//        {"id":"1","method":"slim.request","params":["",["favorites","items","0","5","want_url:1"]]}
        return RequestToVolumioRest.create(player, new String[]{"favorites", "items", "0", "want_url:0"});
    }

    public static RequestToVolumioRest favoritesAdd(String player, String url, String title) {
//        {"id":"1","method":"slim.request","params":["",["favorites","add","url:http://prem2.di.fm/chillout_hi?78------7ceab43a2","title:SSSSS"]]}
        return RequestToVolumioRest.create(player, new String[]{"favorites", "add", "url:" + url, "title:" + title});
    }

    public static RequestToVolumioRest volume(String player, String value) {
        return RequestToVolumioRest.create(player, new String[]{"mixer", "volume", value});
    }

    public static RequestToVolumioRest volume(String player) {
        return RequestToVolumioRest.create(player, new String[]{"mixer", "volume", "?"});
    }

    public static RequestToVolumioRest path(String player) {
        return RequestToVolumioRest.create(player, new String[]{"path", "?"});
    }

    public static RequestToVolumioRest playlistname(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "name", "?"});
    }

    public static RequestToVolumioRest playlisturl(String player) {
        return RequestToVolumioRest.create(player, new String[]{player, "playlist", "url", "?"});
    }

    public static RequestToVolumioRest albumname(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "album", "?"});
    }

    public static RequestToVolumioRest trackname(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "title", "?"});
    }

    public static RequestToVolumioRest artistname(String player) {
        return RequestToVolumioRest.create(player, new String[]{"artist", "?"});
    }

    public static RequestToVolumioRest syncgroups() {
            return RequestToVolumioRest.create("", new String[]{"syncgroups", "?"});
    }

    public static RequestToVolumioRest unsync(String player) {
        return RequestToVolumioRest.create(player, new String[]{"sync", "-"});
    }

    public static RequestToVolumioRest sync(String player, String head) {
        return RequestToVolumioRest.create(head, new String[]{"sync", player});
    }

    public static RequestToVolumioRest shuffleOn(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "shuffle", "1"});
    }

    public static RequestToVolumioRest shuffleOff(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "shuffle", "0"});
    }

    public static RequestToVolumioRest repeatOn(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "repeat", "1"});
    }

    public static RequestToVolumioRest repeatOff(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "repeat", "0"});
    }

    public static RequestToVolumioRest prevtrack(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "jump", "-1"});
    }

    public static RequestToVolumioRest nexttrack(String player) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "jump", "+1"});
    }


    public static RequestToVolumioRest track(String player, String track) {
        return RequestToVolumioRest.create(player, new String[]{"playlist", "jump", track});
    }

    public static RequestToVolumioRest tracks(String player) {
//        {"id": 1, "method": "slim.request", "params":["HomePod", ["playlist", "tracks", "?"]]}
        return RequestToVolumioRest.create(player, new String[]{"playlist", "tracks", "?"});
    }

    public static RequestToVolumioRest serverstatusname() {
//        {"id": 1, "method": "slim.request", "params":["HomePod2", ["status", "1", "1"]]}
//        "player count": 5,
        return RequestToVolumioRest.create("", new String[]{"serverstatus", "name"});
    }

    public static RequestToVolumioRest status(String player, Integer tracks) {
//        {"id": 1, "method": "slim.request", "params":["HomePod2", ["status", "1", "1"]]}
        return RequestToVolumioRest.create(player, new String[]{"status", "0", String.valueOf(tracks)});
    }
}