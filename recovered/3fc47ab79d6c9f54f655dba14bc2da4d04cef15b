@startuml
set separator none
title Диаграмма развёртывания

left to right direction

hide stereotype

skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
}

skinparam rectangle<<group>> {
  BorderColor #888888
}

skinparam database<<database>> {
  BackgroundColor #adb5b6
  BorderColor #2e6295
}

skinparam queue<<messageBroker>> {
  BackgroundColor #fcb0a4
  BorderColor #2e6295
}

skinparam rectangle<<ingressController>> {
  BackgroundColor #d7e8ea
  BorderColor #2e6295
}

skinparam rectangle<<haProxy>> {
  BackgroundColor #d7e8ea
  BorderColor #2e6295
}

skinparam rectangle<<service>> {
  BackgroundColor #7fc37d
  BorderColor #2e6295
}

skinparam rectangle<<onlineService>> {
  BackgroundColor #7baadc
  BorderColor #2e6295
}

skinparam rectangle<<cbService>> {
  BackgroundColor #d5bbd6
  BorderColor #2e6295
}

skinparam rectangle<<framosService>> {
  BackgroundColor #cae9bf
  BorderColor #2e6295
}

skinparam rectangle<<dseService>> {
  BackgroundColor #ccc0e8
  BorderColor #2e6295
}

skinparam rectangle<<mlService>> {
  BackgroundColor #fbf09e
  BorderColor #2e6295
}

!procedure $group($name)
rectangle "$name" <<group>> #line.dotted
!endprocedure

!procedure $postgreSql($name, $host)
database "==PostgreSQL\n<size:10>[$host]</size>" <<database>> as $name
!endprocedure

!procedure $rabbitMq($name, $description)
queue "==$description" <<messageBroker>> as $name
!endprocedure

!procedure $ingressController($name)
rectangle "==Ingress Controller" <<ingressController>> as $name
!endprocedure

!procedure $haProxy($name, $host)
rectangle "==HAProxy\n<size:10>[$host]</size>" <<haProxy>> as $name
!endprocedure

!procedure $service()
rectangle "==Service" <<service>> as service
!endprocedure

!procedure $onlineService($name, $description)
rectangle "==$description" <<onlineService>> as $name
!endprocedure

!procedure $cbService($name, $description)
rectangle "==$description" <<cbService>> as $name
!endprocedure

!procedure $framosService($name, $description)
rectangle "==$description" <<framosService>> as $name
!endprocedure

!procedure $dseService($name, $description, $host)
rectangle "==$description\n<size:10>[$host]</size>" <<dseService>> as $name
!endprocedure

!procedure $mlService($name, $description)
rectangle "==$description" <<mlService>> as $name
!endprocedure

!procedure $link($from, $to, $text)
$from .[#707070,thickness=2].> $to : "[$text]"
!endprocedure

!procedure $hiddenLink($from, $to)
$from .[hidden].> $to : ""
!endprocedure

$group("dse") {
    $haProxy("haproxyLbDse", "dplbdse.ftc.ru")

    $dseService("logstash", "Logstash", "dpelk01.ftc.ru")

    $dseService("jaeger", "Jaeger Collector", "jaeger01.ftc.ru")
}

$group("kubernetes [dp_k8s.ftc.ru]") {
    $group("namespace online") {
        $group("Loans Scoring Service") {
            $service()

            $postgreSql("loansScoringPostgresql", "loansScoringPostgresql")
        }

        $rabbitMq("loansRabbitMQ", "Loans RabbitMQ")

        $ingressController("onlineIngressController")

        $onlineService("authorizationService", "Authorization Service")

        $onlineService("referenceDataService", "Reference Data Service")

        $onlineService("photoCheckService", "Client")
    }

    $group("namespace cb") {
        $rabbitMq("cbRabbitMQ", "Cb RabbitMQ")
        $ingressController("cbIngressController")
    }

    $group("namespace mo") {
        $ingressController("moIngressController")
        $mlService("abram", "Abram\nml-credit-scoring")
    }

    $group("namespace framos") {
        $framosService("inspector", "Inspector")
    }
}

$link("service", "haproxyLbDse", "http:15151")
$link("service", "jaeger", "http:14268")
$link("service", "loansRabbitMQ", "tcp:5672")
$link("service", "loansScoringPostgresql", "tcp:5432")
$link("service", "logstash", "tcp:25701")
$link("service", "onlineIngressController", "http:80")
$link("service", "onlineIngressController", "http:80")
$link("service", "onlineIngressController", "ws:80")
$link("haproxyLbDse", "inspector", "http:8080")
$link("onlineIngressController", "authorizationService", "http:80")
$link("onlineIngressController", "photoCheckService", "http:80")
$link("onlineIngressController", "referenceDataService", "ws:80")
$hiddenLink("loansScoringPostgresql", "inspector")
@enduml
