    public static String whatsPlaying(Player player) {
        if (player == null) return "плеер не найден";
        log.info("WHATS PLAYING ON " + player.name);
        player.status();
        if (!player.connected) return "плеер " + player.name + " не подключен к медиасерверу";
        log.info("");

        String title = player.title;
        String separate = player.separate ? "отдельно " : "";

        List<String> otherPlayingPlayers = lmsPlayers.playingPlayersNames(player.name);
        log.info("PLAYIND PLAYERS: " + otherPlayingPlayers.toString());
        String other = "";
        if (otherPlayingPlayers.size() == 1) other = " еще играет " + String.join(", ", otherPlayingPlayers);
        if (otherPlayingPlayers.size() > 1) other = " еще играют " + String.join(", ", otherPlayingPlayers);

        String answer;
        if ("play".equals(player.mode)) {
            answer = "сейчас на " + player.name + " играет " + separate + title + " громкость " + player.volume + other;
        } else {
            answer = "сейчас на " + player.name + " не играет " + separate + title + other;
        }
        log.info("ANSWER: " + answer);
        return answer;
    }

