package org.example;

import org.eclipse.paho.client.mqttv3.*;
import org.eclipse.paho.client.mqttv3.persist.MemoryPersistence;

public class HiveMQPublisher {

    // Данные вашего HiveMQ Cloud аккаунта
    private static final String BROKER = "ssl://811c56b338f24aeea3215cd680851784.s1.eu.hivemq.cloud:8883";
    private static final String CLIENT_ID = "JavaClient";
    private static final String USERNAME = "novashki";
    private static final String PASSWORD = "Darthvader0";
//    private static final String TOPIC = "test/topic";
    private static final String TOPIC = "test";

    public static void main(String[] args) {
        try {
            MqttClient client = new MqttClient(
                    BROKER,
                    CLIENT_ID,
                    new MemoryPersistence()
            );

            // Настройки подключения
            MqttConnectOptions options = new MqttConnectOptions();
            options.setCleanSession(true);
            options.setUserName(USERNAME);
            options.setPassword(PASSWORD.toCharArray());
            options.setAutomaticReconnect(true);

            System.out.println("Connecting to HiveMQ Cloud...");
            client.connect(options);
            System.out.println("Connected!");

            // Создание и отправка сообщения
            String content = "Hello from Java Client!";
            MqttMessage message = new MqttMessage(content.getBytes());
            message.setQos(0); // Уровень качества обслуживания (0, 1 или 2)

            client.publish(TOPIC, message);
            System.out.println("Message published to topic: " + TOPIC);

            // Отключение
            client.disconnect();
            System.out.println("Disconnected");

        } catch (MqttException e) {
            e.printStackTrace();
        }
    }
}