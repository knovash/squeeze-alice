package org.knovash.squeezealice;

import com.sun.net.httpserver.*;
import lombok.extern.log4j.Log4j2;
import org.eclipse.paho.client.mqttv3.*;
import org.eclipse.paho.client.mqttv3.persist.MemoryPersistence;
import org.knovash.squeezealice.utils.HandlerUtils;

import javax.net.ssl.SSLContext;
import java.io.*;
import java.net.InetSocketAddress;
import java.nio.charset.StandardCharsets;
import java.security.NoSuchAlgorithmException;
import java.util.Map;
import java.util.UUID;
import java.util.concurrent.*;

@Log4j2
public class MqttGatewayServer {

    //    private static final String MQTT_BROKER = "ssl://YOUR_CLUSTER.s1.eu.hivemq.cloud:8883";
    private static final String MQTT_CLIENT_ID = "ddfdsfsfsd";
    //    private static final String MQTT_USERNAME = "your-username";
//    private static final String MQTT_PASSWORD = "your-password";
    private static final String MQTT_BROKER = "ssl://811c56b338f24aeea3215cd680851784.s1.eu.hivemq.cloud:8883";
    private static final String MQTT_USERNAME = "novashki";
    private static final String MQTT_PASSWORD = "Darthvader0";

//    private static final String REQUEST_TOPIC = "to_lms";
//    private static final String RESPONSE_TOPIC = "from_lms";
    private static final String REQUEST_TOPIC = "qqq";
    private static final String RESPONSE_TOPIC = "aaa";

    private static MqttClient mqttClient;
    private static HttpServer httpServer;
    private static final Map<String, CompletableFuture<String>> pendingRequests = new ConcurrentHashMap<>();
    private static final ScheduledExecutorService timeoutExecutor = Executors.newScheduledThreadPool(1);

    public static void main(String[] args) throws Exception {
        initializeMqtt();
        startHttpServer(8080);
        addShutdownHook();
    }

    private static void initializeMqtt() throws MqttException {
        mqttClient = new MqttClient(MQTT_BROKER, MQTT_CLIENT_ID, new MemoryPersistence());

        MqttConnectOptions options = new MqttConnectOptions();
        options.setUserName(MQTT_USERNAME);
        options.setPassword(MQTT_PASSWORD.toCharArray());
        options.setAutomaticReconnect(true);
        options.setCleanSession(true);

        // Добавьте SSL-конфигурацию
        try {
            options.setSocketFactory(SSLContext.getDefault().getSocketFactory());
        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException(e);
        }
        options.setHttpsHostnameVerificationEnabled(false); // Только для тестирования!

        mqttClient.setCallback(new MqttCallback() {
            @Override
            public void connectionLost(Throwable cause) {
                System.out.println("MQTT connection lost: " + cause.getMessage());
            }

            @Override
            public void messageArrived(String topic, MqttMessage message) {
                if (RESPONSE_TOPIC.equals(topic)) {
                    handleResponseMessage(new String(message.getPayload()));
                }
            }

            @Override
            public void deliveryComplete(IMqttDeliveryToken token) {
            }
        });

        mqttClient.connect();
        mqttClient.subscribe(RESPONSE_TOPIC, 1);
    }

    private static void handleResponseMessage(String payload) {
        String[] parts = payload.split("\\|", 2);
        if (parts.length == 2) {
            String requestId = parts[0];
            String responseBody = parts[1];

            CompletableFuture<String> future = pendingRequests.remove(requestId);
            if (future != null) {
                future.complete(responseBody);
            }
        }
    }

    private static void startHttpServer(int port) throws IOException {
        httpServer = HttpServer.create(new InetSocketAddress(port), 0);
        httpServer.createContext("/api", new ApiHandler());
        httpServer.setExecutor(Executors.newCachedThreadPool());
        httpServer.start();
        System.out.println("HTTP server started on port " + port);
    }

    static class ApiHandler implements HttpHandler {

        @Override
        public void handle(HttpExchange exchange) throws IOException {
            try {
                Context context = HandlerUtils.contextCreate(exchange);
                log.info("PATH: " + context.path);
                // Чтение тела запроса
                String requestBody = context.toString();

                String response = null;


                if (context.path.equals("/v1.0/user/devices/action")) {
//                    выполнить обработку запроса тут в облаке
                    context = Handler.switchContext(context);
                    response = context.json;

                } else {
//                    отправить запрос на обработку в дом

                    // Генерация уникального ID запроса
                    String requestId = UUID.randomUUID().toString();
                    CompletableFuture<String> responseFuture = new CompletableFuture<>();
                    pendingRequests.put(requestId, responseFuture);
                    // Отправка запроса в MQTT context.toString()
                    sendMqttRequest(requestId, requestBody);
                    // Ожидание ответа с таймаутом
                    response = "TIME OUT 10";
                    response = responseFuture.get(10, TimeUnit.SECONDS);

                }


                // Отправка ответа клиенту
                exchange.getResponseHeaders().putAll(context.headers);
//                exchange.getResponseHeaders().set("Content-Type", "application/json");
                exchange.sendResponseHeaders(200, response.length());
                try (OutputStream os = exchange.getResponseBody()) {
                    os.write(response.getBytes());
                }
            } catch (TimeoutException e) {
                sendErrorResponse(exchange, 504, "Gateway Timeout");
            } catch (Exception e) {
                sendErrorResponse(exchange, 500, "Internal Server Error");
                e.printStackTrace();
            } finally {
                exchange.close();
            }



        }

        private void sendMqttRequest(String requestId, String body) throws MqttException {
            String payload = requestId + "|" + body;
            MqttMessage message = new MqttMessage(payload.getBytes());
            message.setQos(1);
            mqttClient.publish(REQUEST_TOPIC, message);
        }

        private void sendErrorResponse(HttpExchange exchange, int code, String message) throws IOException {
            byte[] response = message.getBytes(StandardCharsets.UTF_8);
            exchange.sendResponseHeaders(code, response.length);
            try (OutputStream os = exchange.getResponseBody()) {
                os.write(response);
            }
        }
    }

    private static void addShutdownHook() {
        Runtime.getRuntime().addShutdownHook(new Thread(() -> {
            try {
                System.out.println("Shutting down...");
                mqttClient.disconnect();
                httpServer.stop(1);
                timeoutExecutor.shutdown();
            } catch (Exception e) {
                e.printStackTrace();
            }
        }));
    }
}